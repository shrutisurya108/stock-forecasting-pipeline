# ──────────────────────────────────────────────────────────────────────────────
# .streamlit/secrets.toml.example
# Template for Streamlit Cloud secrets.
#
# In Streamlit Cloud UI:
#   Your app → Settings (⚙️) → Secrets → paste content below with real values
#
# Streamlit makes these available as environment variables automatically,
# so os.environ["AWS_ACCESS_KEY_ID"] works in app.py.
# ──────────────────────────────────────────────────────────────────────────────

AWS_ACCESS_KEY_ID     = "your_aws_access_key_here"
AWS_SECRET_ACCESS_KEY = "your_aws_secret_key_here"
AWS_REGION            = "us-east-1"
S3_BUCKET_NAME        = "stock-forecasting-pipeline"
